# /etc/smart-shield/env として配置 (chmod 600)
#
# 使用する AI プロバイダのキーだけを設定すればよい (両方は不要)。
# どちらを使うかは shield.yaml の ai.provider で切り替える。

# --- Gemini を使う場合 (ai.provider: gemini / デフォルト) ---
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY でも可 (GEMINI_API_KEY が優先される)

# --- Anthropic を使う場合 (ai.provider: anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
